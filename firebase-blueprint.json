{
  "entities": {
    "Expense": {
      "title": "Expense",
      "description": "A personal expense record.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the expense."
        },
        "title": {
          "type": "string",
          "description": "The title or description of the expense."
        },
        "amount": {
          "type": "number",
          "description": "The amount of the expense."
        },
        "category": {
          "type": "string",
          "description": "The category of the expense.",
          "enum": ["Food", "Travel", "Bills", "Entertainment", "Other"]
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "The date of the expense in ISO format."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the expense was created."
        }
      },
      "required": ["userId", "title", "amount", "category", "date", "createdAt"]
    }
  },
  "firestore": {
    "/expenses/{expenseId}": {
      "schema": {
        "$ref": "#/entities/Expense"
      },
      "description": "Stores the expenses for all users, filtered by userId."
    }
  }
}
